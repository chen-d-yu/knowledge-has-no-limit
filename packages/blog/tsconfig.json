{
  "compilerOptions": {
    "module": "ESNext",
    "baseUrl": ".",
    "target": "es2016",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": [
      "vite/client",
      "node"
    ],
    "paths": {
      "@/*": [
        "./docs/.vitepress/*"
      ]
    }
  },
  "include": [
    "shims.d.ts",
    "./*.ts",
    "./*.d.ts",
    "./docs/vite.config.ts",
    "docs/.vitepress/*",
    "docs/.vitepress/**/*.ts",
    "docs/.vitepress/**/*.vue"
  ],
  "exclude": [
    "**/dist/**",
    "node_modules"
  ]
}
